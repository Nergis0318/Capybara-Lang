`불린 값 다양한 형태 테스트`

set;["참1"]:(true)
set;["참2"]:(True)
set;["참3"]:(TRUE)
set;["참4"]:(TrUe)

set;["거짓1"]:(false)
set;["거짓2"]:(False)
set;["거짓3"]:(FALSE)

<print:("다양한 형태의 불린 값들이 모두 정상적으로 인식됩니다.")>

set;["pop"]:(true)

if {<pop> = true}
<-
<print:("대소문자 관계없이 true로 인식됩니다!")>
->
el {}
<-
<print:("불린 인식에 문제가 있습니다.")>
