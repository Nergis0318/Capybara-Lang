`산술 및 비교 연산 테스트`

set;["a"]:(10)
set;["b"]:(3)

set;["합"]:(a + b)
set;["차"]:(a - b)
set;["곱"]:(a * b)
set;["몫"]:(a / b)
set;["나머지"]:(a % b)

<print:(합)>
<print:(차)>
<print:(곱)>
<print:(몫)>
<print:(나머지)>

if {합 = 13}
<-
<print:("덧셈 성공")>
->

if {차 > 0}
<-
<print:("뺄셈 성공")>
->

if {곱 < 50}
<-
<print:("곱셈 성공")>
->

if {몫 >= 3}
<-
<print:("나눗셈 성공")>
->

if {나머지 <= 2}
<-
<print:("나머지 성공")>
->

if {나머지 != 0}
<-
<print:("not equal 성공")>
->
