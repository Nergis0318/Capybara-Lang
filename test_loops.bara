`반복문 테스트`

`1부터 10까지 합계`
set;["합계"]:(0)
set;["i"]:(1)

wh {i <= 10}
<-
set;["합계"]:(합계 + i)
set;["i"]:(i + 1)
->

<print:(합계)>

`5! 계산`
set;["n"]:(5)
set;["결과"]:(1)

wh {n > 0}
<-
set;["결과"]:(결과 * n)
set;["n"]:(n - 1)
->

<print:(결과)>

`구구단 2단`
set;["j"]:(1)

wh {j <= 9}
<-
set;["곱"]:(2 * j)
<print:(곱)>
set;["j"]:(j + 1)
->

`and/or 테스트`
set;["x"]:(true)
set;["y"]:(false)

if {x and y}
<-
<print:("and 실패")>
->

if {x or y}
<-
<print:("or 성공")>
->

if {!y}
<-
<print:("not 성공")>
->
